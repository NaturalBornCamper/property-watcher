# Copy this file to settings.env (same folder as email-to-html.sh) and edit.
# It is sourced by bash: KEY="value", no spaces around '=', LF line endings.
# Keep it private on the server: chmod 600 settings.env

# REQUIRED. Folder the HTML files are written to. Point this at the document
# root of the subdomain that should serve them, e.g. a subdomain created in
# cPanel with document root /home/YOURUSER/alerts.yourdomain.com
OUTPUT_DIR="/home/YOURUSER/alerts.yourdomain.com"

# Strongly recommended. Sender domains allowed to publish, separated by
# spaces; email from any other domain is logged and dropped. Subdomains
# match automatically ("centris.ca" also accepts mail from @e.centris.ca).
# Without this, anyone who discovers the pipe address can publish HTML on
# your subdomain.
ALLOWED_SENDER_DOMAINS="centris.ca duproprio.com realtor.ca kijiji.ca logisquebec.com"

# Optional. Log file (default: pipe.log next to the script; auto-rotated
# once it passes ~1 MB).
#LOG_FILE="/home/YOURUSER/email-pipe/pipe.log"

# Optional. Where raw emails are saved when extraction fails
# (default: failed/ next to the script).
#FAILED_DIR="/home/YOURUSER/email-pipe/failed"

# Optional. If set, a timestamped copy (e.g. centris-20260703-153000.html)
# is also kept here, so a second alert on the same day does not overwrite
# the first one before you have read it.
#ARCHIVE_DIR="/home/YOURUSER/email-pipe/archive"
